{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "declaration": false
  },
  "include": ["index.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
