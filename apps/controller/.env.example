# ── Server ────────────────────────────────────────────
# PORT=3010
# HOST=127.0.0.1

# ── OpenClaw ──────────────────────────────────────────
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BIN=openclaw

# ── Runtime ───────────────────────────────────────────
# RUNTIME_MANAGE_OPENCLAW_PROCESS=false
# RUNTIME_GATEWAY_PROBE_ENABLED=true

# ── nene-web adapter (Phase 1 placeholders) ──────────
# NENE_HOME=~/.nexu
# NENE_WEB_BASE_URL=https://nene.im
# NENE_DESKTOP_APP_ID=nene-desktop-open-source
# NENE_UPDATE_CHANNEL=stable

# ── Model ─────────────────────────────────────────────
# DEFAULT_MODEL_ID=anthropic/claude-sonnet-4
