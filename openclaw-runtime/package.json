{
  "name": "openclaw-runtime",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "clean": "node ./clean-node-modules.mjs",
    "install:cached": "node ./postinstall.mjs",
    "install:full": "node ./install-runtime.mjs full",
    "install:pruned": "node ./install-runtime.mjs pruned && node ./prune-runtime.mjs",
    "refresh-lock": "npm install && node ./prune-runtime.mjs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "openclaw": "2026.3.7"
  },
  "optionalDependencies": {
    "@snazzah/davey-darwin-arm64": "^0.1.10"
  }
}
